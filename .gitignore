!custom_components/tortoise_ufh/brand/*.png
!custom_components/tortoise_ufh/frontend/panel-icon.png
!brand-submission/tortoise_ufh/*.png

# HA dev container runtime state (keep only the hand-written config)
docker/config/*
!docker/config/configuration.yaml

